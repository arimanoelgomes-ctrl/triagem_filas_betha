# Configuração dos scripts auxiliares (post_comentarios.js + registrar_uso_tokens.js)
# Copie este arquivo para .env (mesma pasta) e preencha com suas credenciais.
# IMPORTANTE: scripts/.env está no .gitignore — nunca será commitado.

# URL base do Jira da Betha
JIRA_BASE_URL=https://atendimento.betha.com.br

# Usuário do Jira (mesmo usado no MCP, ex: mcpintegracao ou seu usuário pessoal)
JIRA_USERNAME=seu_usuario_aqui

# Senha ou Personal Access Token do Jira
# Recomendado: usar token (mais seguro), gerado no Jira em "Profile → Personal Access Tokens"
JIRA_PASSWORD=sua_senha_ou_token_aqui

# ─── Anthropic Admin Usage API (registrar_uso_tokens.js) ───────────────────
# Admin Key da organizacao Anthropic (sk-ant-admin01-...). Gerada por um Owner
# da organizacao em console.anthropic.com -> Settings -> Admin Keys.
# IMPORTANTE: chaves de API normais (sk-ant-api03-...) NAO funcionam aqui —
# a Usage API so aceita Admin Keys. Se voce nao tem acesso, deixe em branco;
# o script gravara um placeholder com instrucoes manuais.
ANTHROPIC_ADMIN_API_KEY=
